<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>

        <!-- Connexion à MySQL -->
        <property name="hibernate.connection.driver_class">
            com.mysql.cj.jdbc.Driver
        </property>
        <property name="hibernate.connection.url">
            jdbc:mysql://localhost:3306/daara?serverTimezone=UTC&amp;allowPublicKeyRetrieval=true
        </property>
        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password"></property>

        <!-- Dialecte SQL utilisé par Hibernate -->
        <property name="hibernate.dialect">
            org.hibernate.dialect.MySQLDialect
        </property>

        <!-- Affichage et formatage du SQL généré -->
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>
        <property name="hibernate.use_sql_comments">true</property>

        <!-- update = met à jour sans effacer les données -->
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- Les 4 entités JPA du projet Daara -->
        <mapping class="sn.l2gl.girls.daara.model.models.Maitre"/>
        <mapping class="sn.l2gl.girls.daara.model.models.Classe"/>
        <mapping class="sn.l2gl.girls.daara.model.models.Talibe"/>
        <mapping class="sn.l2gl.girls.daara.model.models.Progression"/>

    </session-factory>
</hibernate-configuration>